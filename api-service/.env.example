# ─── Server ────────────────────────────────────────────────────────────────────
# Railway injects PORT automatically — leave this unset in Railway Variables.
PORT=5000
NODE_ENV=production

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# On Railway: copy the DATABASE_URL from your PostgreSQL service's Variables tab.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=postgresql://postgres:password@localhost:5432/point_ledger

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI must be: https://<your-api-service>.up.railway.app/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-api-service.up.railway.app/api/auth/google/callback

# ─── Frontend URL (used for OAuth redirects and CORS) ─────────────────────────
# Set this to your Railway frontend service URL once deployed.
FRONTEND_URL=https://your-frontend-service.up.railway.app

# ─── Encryption key for card data (exactly 32 characters) ────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
ENCRYPTION_KEY=your_exactly_32_char_encryption_key

# ─── Migrations (optional) ────────────────────────────────────────────────────
# Only needed if Railway can't find the db/migrations folder automatically.
# Leave blank — the server auto-detects the correct path.
# MIGRATIONS_DIR=/app/db/migrations
